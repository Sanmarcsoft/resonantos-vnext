{
  "id": "addon.browser",
  "name": "Resonant Browser",
  "version": "0.1.0",
  "author": "Resonant Alpha",
  "category": "tool",
  "sdkVersion": "0.1.0",
  "description": "Live internal browser add-on for web work and future AI-controlled browsing. V1 uses a live center-workspace web frame, while the AI-control host is a separate audited Chromium service.",
  "runtimeType": "local-service",
  "surfaces": [
    {
      "id": "browser-pane",
      "type": "embedded-pane",
      "label": "Browser",
      "description": "Open the live Browser workspace inside the ResonantOS center column."
    }
  ],
  "requestedCapabilities": [
    {
      "capability": "network",
      "granted": false,
      "scope": "shared",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "ui-embedding",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hide-surface"
    },
    {
      "capability": "browser-control",
      "granted": false,
      "scope": "system",
      "revocationBehavior": "hard-stop"
    },
    {
      "capability": "archive-intake-write",
      "granted": false,
      "scope": "intake-only",
      "revocationBehavior": "degrade"
    }
  ],
  "provenance": {
    "tier": "curated-signed",
    "verificationState": "verified",
    "signed": true,
    "signer": "ResonantOS bundled catalog"
  },
  "runtimeIsolation": {
    "boundary": "host-mediated-service",
    "supportsDegradedMode": true,
    "requiresReviewedGrant": true
  },
  "grantPresets": [
    {
      "id": "browser-controlled-session",
      "label": "Live Chromium session",
      "description": "Allows ResonantOS to attach a live browser surface and future audited AI-control tools.",
      "grants": [
        {
          "capability": "network",
          "granted": true,
          "scope": "shared",
          "revocationBehavior": "hard-stop"
        },
        {
          "capability": "ui-embedding",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hide-surface"
        },
        {
          "capability": "browser-control",
          "granted": true,
          "scope": "system",
          "revocationBehavior": "hard-stop"
        }
      ]
    }
  ],
  "providerRequirements": {
    "sharedProfiles": [],
    "supportsPrivateCredentials": false
  },
  "archiveIntegration": {
    "readScopes": [],
    "intakeWriteScopes": ["LivingArchive/INTAKE/browser"],
    "canRequestIngest": true,
    "canWriteKnowledgePages": false
  },
  "health": {
    "strategy": "browser-engine-ready"
  },
  "service": {
    "protocol": "stdio-json-rpc",
    "entrypoint": "addons/resonant-browser-host/src/browser-host.mjs",
    "healthCommand": "browser.health",
    "shutdownCommand": "browser.close"
  },
  "tools": [
    {
      "name": "browser.health",
      "description": "Check the controlled Chromium browser host state.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object"
      },
      "outputSchema": {
        "type": "object",
        "required": ["ready", "engine", "audit"],
        "properties": {
          "ready": { "type": "boolean" },
          "sessionId": { "type": "string" },
          "engine": { "type": "string" },
          "url": { "type": "string" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.start",
      "description": "Start the controlled Chromium browser host and open the default or requested URL.",
      "requiredCapabilities": ["network", "browser-control"],
      "inputSchema": {
        "type": "object",
        "properties": {
          "defaultUrl": { "type": "string" },
          "headless": { "type": "boolean" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["ready", "engine", "audit"],
        "properties": {
          "ready": { "type": "boolean" },
          "sessionId": { "type": "string" },
          "engine": { "type": "string" },
          "url": { "type": "string" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.open_url",
      "description": "Open or navigate the live Chromium browser session and return URL, title, status, and audit events.",
      "requiredCapabilities": ["network", "browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["sessionId", "finalUrl", "title", "status", "audit"],
        "properties": {
          "sessionId": { "type": "string" },
          "finalUrl": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log", "citation-bundle"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.read_page",
      "description": "Read title, final URL, body text, and links from the active Chromium session.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["sessionId"],
        "properties": {
          "sessionId": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["sessionId", "finalUrl", "title", "text", "links", "audit"],
        "properties": {
          "sessionId": { "type": "string" },
          "finalUrl": { "type": "string" },
          "title": { "type": "string" },
          "text": { "type": "string" },
          "links": { "type": "array" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log", "citation-bundle"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.click",
      "description": "Click the active Chromium session by audited selector or coordinates.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" },
          "selector": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["sessionId", "finalUrl", "title", "audit"],
        "properties": {
          "sessionId": { "type": "string" },
          "finalUrl": { "type": "string" },
          "title": { "type": "string" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.type",
      "description": "Type into the active Chromium session by audited selector.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["selector", "text"],
        "properties": {
          "sessionId": { "type": "string" },
          "selector": { "type": "string" },
          "text": { "type": "string" },
          "sensitive": { "type": "boolean" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["sessionId", "finalUrl", "title", "audit"],
        "properties": {
          "sessionId": { "type": "string" },
          "finalUrl": { "type": "string" },
          "title": { "type": "string" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.capture_evidence",
      "description": "Capture explicit evidence from the active live browser session when requested.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["sessionId"],
        "properties": {
          "sessionId": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["sessionId", "evidenceRef", "audit"],
        "properties": {
          "sessionId": { "type": "string" },
          "evidenceRef": { "type": "string" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log", "citation-bundle"]
      },
      "requiresHumanApproval": false
    },
    {
      "name": "browser.close_session",
      "description": "Close a host-managed Chromium browser session and clean up its local profile directory.",
      "requiredCapabilities": ["browser-control"],
      "inputSchema": {
        "type": "object",
        "required": ["sessionId"],
        "properties": {
          "sessionId": { "type": "string" }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["sessionId", "closed", "audit"],
        "properties": {
          "sessionId": { "type": "string" },
          "closed": { "type": "boolean" },
          "audit": { "type": "array" }
        }
      },
      "audit": {
        "logRequest": true,
        "logResult": true,
        "artifactTypes": ["log"]
      },
      "requiresHumanApproval": false
    }
  ],
  "delegation": {
    "acceptsTasks": true,
    "taskTypes": ["research", "browser-inspection"],
    "artifactReturnTypes": ["summary", "markdown", "log", "citation-bundle", "diagnostic-report"],
    "defaultTargetRuntime": "local-service",
    "requiresHumanApprovalBeforeExecution": false,
    "notes": [
      "Prefer API research for normal web lookup.",
      "Use browser delegation when visual inspection, login, forms, live page interaction, or web app testing are required.",
      "AI control must be routed through audited browser-session tools, not direct hidden DOM automation."
    ]
  },
  "installHooks": {
    "onInstall": "register-browser-surface"
  },
  "compatibility": {
    "shellVersion": "^0.1.0",
    "platforms": ["macOS", "linux", "windows"]
  }
}
