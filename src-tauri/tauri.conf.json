{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResonantOS",
  "version": "0.1.0",
  "identifier": "com.resonantos.vnext",
  "build": {
    "beforeDevCommand": "node scripts/ensure-dev-server.mjs",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ResonantOS",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../docs",
      "../addons/resonant-browser-host",
      "../build/native-browser"
    ]
  }
}
